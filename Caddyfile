# Media domain — serves user uploads from a separate origin for security
# Set MEDIA_DOMAIN env var to enable (e.g. media.hybridsocial.com)
{$MEDIA_DOMAIN:} {
	# Only serve uploads — no cookies, no scripts
	header {
		X-Content-Type-Options nosniff
		Content-Security-Policy "default-src 'none'; img-src 'self'; media-src 'self'; style-src 'none'; script-src 'none'"
		X-Frame-Options DENY
		-Server
		-Set-Cookie
	}

	handle /uploads/* {
		reverse_proxy backend:4000
	}

	# Block everything else
	handle {
		respond "Not Found" 404
	}

	encode gzip zstd
}

{$DOMAIN:localhost} {
	# Frontend (SvelteKit)
	handle /api/* {
		reverse_proxy backend:4000
	}

	handle /.well-known/* {
		reverse_proxy backend:4000
	}

	handle /nodeinfo/* {
		reverse_proxy backend:4000
	}

	handle /inbox {
		reverse_proxy backend:4000
	}

	handle /users/* {
		reverse_proxy backend:4000
	}

	handle /actors/* {
		reverse_proxy backend:4000
	}

	handle /activities/* {
		reverse_proxy backend:4000
	}

	handle /oauth/* {
		reverse_proxy backend:4000
	}

	handle /media/* {
		reverse_proxy backend:4000
	}

	# WebSocket streaming
	handle /api/v1/streaming/* {
		reverse_proxy backend:4000 {
			transport http {
				read_timeout 0
			}
		}
	}

	# Everything else goes to frontend
	handle {
		reverse_proxy frontend:3000
	}

	# Security headers
	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		-Server
	}

	# Compression
	encode gzip zstd

	# Logging
	log {
		output file /data/access.log {
			roll_size 10mb
			roll_keep 5
		}
	}
}
